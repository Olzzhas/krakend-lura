{
    "$schema": "https://www.krakend.io/schema/v2.13/krakend.json",
    "version": 3,
    "name": "KrakenD - dev",
    "port": 8080,
    "timeout": "3s",
    "cache_ttl": "0s",
    "output_encoding": "json",
    "host": ["http://backend:80"],
    "endpoints": [
        
        
        {
            "endpoint": "/users",
            "method": "GET",
            "input_query_strings": ["page","limit"],
            "backend": [
                {
                    "host": ["http://backend:80"],
                    "url_pattern": "/get"
                }
            ]
        }
        
        ,
        {
            "endpoint": "/ip",
            "method": "GET",
            "backend": [
                {
                    "host": ["http://backend:80"],
                    "url_pattern": "/ip"
                }
            ]
        }
        
        ,
        {
            "endpoint": "/headers",
            "method": "GET",
            "backend": [
                {
                    "host": ["http://backend:80"],
                    "url_pattern": "/headers"
                }
            ]
        }
        
    ]
}